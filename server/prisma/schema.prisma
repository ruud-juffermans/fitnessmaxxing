generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MuscleGroup {
  chest
  back
  shoulders
  biceps
  triceps
  legs
  glutes
  core
  forearms
  calves
  full_body
  cardio
  other
}

enum TokenType {
  email_verification
  password_reset
}

enum UserRole {
  user
  admin
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  emailVerified Boolean   @default(false) @map("email_verified")
  isGuest       Boolean   @default(false) @map("is_guest")
  role          UserRole  @default(user)
  // Null = active; a timestamp marks the account as suspended (and when).
  disabledAt    DateTime? @map("disabled_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions       Session[]
  tokens         VerificationToken[]
  exercises      Exercise[]
  plans          WorkoutPlan[]
  splits         Split[]
  splitExercises SplitExercise[]
  workouts       Workout[]
  workoutSets    WorkoutSet[]

  // Lets the guest-cleanup job efficiently find expired guest accounts.
  @@index([isGuest, createdAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  userAgent String?  @map("user_agent")
  ip        String?
  expiresAt DateTime @map("expires_at")
  // Touched (at most hourly) on authenticated requests. Drives both sliding
  // session expiry and the inactivity-based guest purge.
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model VerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

// The user's personal exercise catalogue. Splits reference these; logged sets
// copy the name so history survives catalogue edits/deletes.
model Exercise {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  name        String
  muscleGroup MuscleGroup @default(other) @map("muscle_group")
  equipment   String?
  notes       String?
  archived    Boolean     @default(false)
  createdAt   DateTime    @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitExercises SplitExercise[]
  workoutSets    WorkoutSet[]

  @@index([userId])
  @@map("exercises")
}

// A workout plan, e.g. "3-Day Split", made up of ordered splits (days).
model WorkoutPlan {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  splits   Split[]
  workouts Workout[]

  @@index([userId])
  @@map("workout_plans")
}

// One day of a plan, e.g. "Back & Biceps".
model Split {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  planId    String   @map("plan_id") @db.Uuid
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      WorkoutPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises SplitExercise[]
  workouts  Workout[]

  @@index([userId])
  @@index([planId])
  @@map("splits")
}

// An exercise inside a split, with its prescription (target sets x reps).
model SplitExercise {
  id           String  @id @default(uuid()) @db.Uuid
  userId       String  @map("user_id") @db.Uuid
  splitId      String  @map("split_id") @db.Uuid
  exerciseId   String  @map("exercise_id") @db.Uuid
  sortOrder    Int     @default(0) @map("sort_order")
  targetSets   Int     @map("target_sets")
  targetReps   Int     @map("target_reps")
  targetWeight Float?  @map("target_weight")
  restSeconds  Int?    @map("rest_seconds")
  notes        String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  split    Split    @relation(fields: [splitId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([splitId])
  @@index([exerciseId])
  @@index([userId])
  @@map("split_exercises")
}

// A logged training session. `name` is copied from the split at start time and
// plan/split links are SetNull, so history is immune to plan edits/deletes.
model Workout {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  planId      String?   @map("plan_id") @db.Uuid
  splitId     String?   @map("split_id") @db.Uuid
  name        String
  notes       String?
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan  WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  split Split?       @relation(fields: [splitId], references: [id], onDelete: SetNull)
  sets  WorkoutSet[]

  @@index([userId, startedAt])
  @@map("workouts")
}

// One set inside a workout. `exerciseName` is denormalised at creation so the
// log survives catalogue deletes; target* carry the prescription, reps/weight
// hold what was actually lifted, completedAt marks the set as done.
model WorkoutSet {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  workoutId    String    @map("workout_id") @db.Uuid
  exerciseId   String?   @map("exercise_id") @db.Uuid
  exerciseName String    @map("exercise_name")
  sortOrder    Int       @default(0) @map("sort_order")
  setNumber    Int       @map("set_number")
  targetReps   Int?      @map("target_reps")
  targetWeight Float?    @map("target_weight")
  reps         Int?
  weight       Float?
  completedAt  DateTime? @map("completed_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout  Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@index([workoutId])
  @@index([userId])
  @@index([exerciseId])
  @@map("workout_sets")
}
