# ─────────────────────────────────────────────────────────────────────────────
# Shared keys — identical set and order across fitnessmaxxing, habitmaxxing
# and journalmaxxing. App-specific keys live at the bottom of this file.
# ─────────────────────────────────────────────────────────────────────────────

# Shared Postgres (provisioned by the ruudjuffermans-infra stack).
# These two must match infra/.env; they're interpolated into DATABASE_URL in
# docker-compose.yml. In local dev, setup-dev.sh points everything at the
# bundled dev Postgres instead.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Server
SERVER_PORT=4000
# Production uses the shared "fitnessmaxxing" database on host `db`. For local
# dev without the infra stack, override this to your own Postgres.
DATABASE_URL=postgresql://postgres:change-me-strong-password@db:5432/fitnessmaxxing?schema=public

# Client
CLIENT_PORT=3001
VITE_API_URL=http://localhost:4001
VITE_APP_TZ=Europe/Amsterdam

# App
APP_TZ=Europe/Amsterdam
NODE_ENV=development
# Allowed browser origins for credentialed CORS (comma separated).
CORS_ORIGIN=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# App-specific keys (fitnessmaxxing)
# ─────────────────────────────────────────────────────────────────────────────

# Auth
# Public URL of the frontend; used to build links in verification/reset emails.
APP_URL=http://localhost:3001
# Session + token lifetimes (optional; sensible defaults if unset).
SESSION_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60
# How long an INACTIVE, un-converted guest account survives before the
# maintenance job deletes it and its data. Activity (any authenticated request)
# resets the clock, so guests who keep using the app are never purged.
GUEST_TTL_DAYS=7
SESSION_COOKIE_NAME=fitnessmaxxing_session
BCRYPT_ROUNDS=12
# Cookie SameSite policy: lax (default), strict, or none. Use "none" (HTTPS only)
# when the client and API are on different sites in production.
COOKIE_SAMESITE=lax
# Force the Secure cookie flag (auto-on in production and when SameSite=none).
COOKIE_SECURE=false

# Email (SMTP). Leave SMTP_HOST empty in dev to print emails (with the link)
# to the server console instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=fitnessmaxxing <no-reply@fitnessmaxxing.local>

# Seed account (created by `prisma db seed`, email pre-verified)
SEED_USER_EMAIL=demo@ruudjuffermans.local
SEED_USER_PASSWORD=password123

# Admin account. The user who registers with this email is promoted to admin on
# server startup (and their email is auto-verified). Leave empty for no admin.
ADMIN_EMAIL=

# Shared secret for the central admin app (ruudjuffermans-infra) to call
# /api/admin/* without a browser session. Must match ADMIN_SERVICE_TOKEN in the
# admin app's env. Generate with: openssl rand -hex 32. Empty disables it.
ADMIN_SERVICE_TOKEN=

# Habit integration: push "workout finished" events to habitmaxxing so habits
# linked to fitness auto-complete. In production the servers share the dokploy
# network (http://habitmaxxing-server:4000); in local dev point at the habit
# server's local port. The token must match habitmaxxing's INTEGRATIONS_TOKEN.
# Either value empty disables the integration.
HABITMAXXING_URL=http://localhost:4000
HABITMAXXING_INTEGRATIONS_TOKEN=
