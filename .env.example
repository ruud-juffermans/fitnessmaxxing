# ─────────────────────────────────────────────────────────────────────────────
# fitnessmaxxing — client-only since the platform consolidation. The backend
# lives in ../ruudjuffermans-server (api.ruudjuffermans.nl) and auth UI in
# ../ruudjuffermans-account (account.ruudjuffermans.nl). The server/ directory
# in this repo is legacy and no longer deployed; its old env keys are gone.
# ─────────────────────────────────────────────────────────────────────────────

# Client (Vite inlines these at build time). The platform server's CORS
# default (FITNESS_URL) expects the dev client on http://localhost:3000.
CLIENT_PORT=3000
# The platform API. Local dev: the ruudjuffermans-server dev process.
VITE_API_URL=http://localhost:4000
# The central account app (login/register/reset live there).
VITE_ACCOUNT_URL=http://localhost:3004
VITE_APP_TZ=Europe/Amsterdam
